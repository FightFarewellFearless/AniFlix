{
  "extends": "@react-native/typescript-config",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@root/*": ["./*"],
      "@component/*": ["./src/component/*"],
      "@utils/*": ["./src/utils/*"],
      "@assets/*": ["./src/assets/*"],
      "@types/*": ["./src/types/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@misc/*": ["./src/misc/*"]
    },
    "module": "es2020",
    "lib": ["ES2023"]
  }
}
