{
  "name": "AniFlix",
  "displayName": "AniFlix",
  "extra": {
    "eas": {
      "projectId": "ccdabe85-93a9-4297-936c-074a7cf27a4a"
    }
  },
  "updates": {
    "checkAutomatically": "NEVER",
    "url": "https://u.expo.dev/ccdabe85-93a9-4297-936c-074a7cf27a4a"
  },
  "android": {
    "runtimeVersion": "1.2.1",
    "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT"],
          "data": [
            { "scheme": "file" },
            { "scheme": "content" },
            { "mimeType": "application/x-cbz" },
            { "mimeType": "application/vnd.comicbook+zip" }
          ]
        },
        {
          "action": "VIEW",
          "category": ["DEFAULT"],
          "data": [
            { "host": "*" },
            { "scheme": "file" },
            { "scheme": "content" },
            { "pathPattern": ".*\\\\.cbz" },
            { "pathPattern": ".*\\\\.cbz" },
            { "pathPattern": ".*\\\\..*\\\\.cbz" },
            { "pathPattern": ".*\\\\..*\\\\.cbz" }
          ]
        }
      ]
  },
  "experiments": {
    "reactCompiler": false
  },
  "plugins": [
    [
      "expo-video",
      {
        "supportsBackgroundPlayback": true,
        "supportsPictureInPicture": true
      }
    ],
    "expo-sqlite",
    "expo-image"
  ]
}
